{
  "permissions": {
    "allow": [
      "Bash(mv \"Light Novel/Book report.pdf\" \"story-notes/research/\")",
      "Bash(mv \"Light Novel/Essay.pdf\" \"story-notes/research/\")",
      "Bash(mv novel/* \"story-notes/world/\")",
      "Bash(mv \"Light Novel\" \"story-notes/writing/\")",
      "Bash(grep -v \".pap$\\\\|.pb$\\\\|.pbf$\\\\|.lbk$\\\\|.log$\\\\|.set$\\\\|.psd$\\\\|.papproject$\\\\|backup\")",
      "Bash(grep -E '\\\\.\\(html|js|css|json\\)$')",
      "Bash(claude-mem install:*)",
      "Read(//c/Users/esteb/.claude/**)",
      "Bash(claude-mem --version)",
      "Bash(claude-mem start:*)",
      "Bash(curl -s http://localhost:37777/health)",
      "Bash(npm root:*)",
      "Bash(where claude-mem:*)",
      "WebFetch(domain:www.ninetypes.co)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo Reminder: test this change in the browser, then commit if it works."
          }
        ]
      }
    ]
  }
}
