{
  "permissions": {
    "allow": [
      "Bash(npm root:*)",
      "WebFetch(domain:www.ninetypes.co)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo Reminder: test this change in the browser, then commit if it works."
          }
        ]
      }
    ]
  }
}
