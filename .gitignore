# Environment / secrets — never commit these
.env
.env.local
.env.*
*.txt
API KEY*

# Editor folders
.vscode/
.idea/

# OS junk
.DS_Store
Thumbs.db

# Story notes — too large/binary for git
story-notes/

# Un-ignore story folder (override *.txt rule above)
!story/
!story/**

# Local development files
node_modules/

# Ignore most of .claude (local settings, cache, usage data)
# but track skills/ so they sync between machines
# Note: must use .claude/* (not .claude/) so git traverses into the directory
.claude/*
!.claude/skills
!.claude/skills/**
